# Copia este archivo como .env (aquí o en la carpeta del curso) y rellena las claves.

# OpenAI: usado para generar una respuesta Y como juez imparcial.
OPENAI_API_KEY=sk-...

# Gemini (Google AI Studio): la otra respuesta a comparar.
# Aceptamos cualquiera de los dos nombres (se prueba GEMINI_API_KEY primero).
GEMINI_API_KEY=AIza...
# GOOGLE_API_KEY=AIza...

# Opcional: trazabilidad con LangSmith
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=comparativa-llms
